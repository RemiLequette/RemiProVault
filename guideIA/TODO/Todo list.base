filters:
  and:
    - file.inFolder("guideIA/TODO/ITEMS")
views:
  - type: table
    name: Table
    filters:
      and:
        - Status != "Done"
    order:
      - file.name
      - Status
      - importance
      - effort
    sort:
      - property: importance
        direction: ASC
      - property: Status
        direction: ASC
    columnSize:
      file.name: 310
